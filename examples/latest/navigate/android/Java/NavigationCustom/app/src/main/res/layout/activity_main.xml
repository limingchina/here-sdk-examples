<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.here.navigationcustom.MainActivity">

    <com.here.sdk.mapview.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/buttons1stRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:onClick="startButtonClicked"
            android:text="Start simulation" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:onClick="stopButtonClicked"
            android:text="Stop simulation" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/buttons2ndRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="2dp"
        app:layout_constraintTop_toBottomOf="@+id/buttons1stRow">

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:onClick="toggleStyleButtonClicked"
            android:text="Toggle indicator style" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:onClick="togglehaloColorButtonClicked"
            android:text="Toggle halo color" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/mapViewFramerateRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="2dp"
        android:padding="4dp"
        android:background="#CCFFFFFF"
        app:layout_constraintTop_toBottomOf="@+id/buttons2ndRow">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MapView FPS:"
            android:layout_gravity="center_vertical"
            android:paddingEnd="4dp"
            android:paddingStart="4dp" />

        <EditText
            android:id="@+id/mapview_framerate"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="60"
            android:textSize="14sp" />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="setMapViewFrameRateClicked"
            android:text="Set"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/guidanceFramerateRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="2dp"
        android:padding="4dp"
        android:background="#CCFFFFFF"
        app:layout_constraintTop_toBottomOf="@+id/mapViewFramerateRow">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guidance FPS:"
            android:layout_gravity="center_vertical"
            android:paddingEnd="4dp"
            android:paddingStart="4dp" />

        <EditText
            android:id="@+id/guidance_framerate"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="30"
            android:textSize="14sp" />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="setGuidanceFrameRateClicked"
            android:text="Set"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

